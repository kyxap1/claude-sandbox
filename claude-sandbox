#!/usr/bin/env bash
set -euo pipefail

[[ -f ~/.claude.json ]] || touch ~/.claude.json

pull=always
if [[ "${BUILD:-false}" == "true" ]]; then
  # Build the image locally from this repo (reusing compose's build config + .env),
  # then run that local image instead of pulling the published one.
  script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  docker compose --project-directory "$script_dir" -f "$script_dir/compose.yaml" build
  pull=never
fi

args=(
  --rm -it --pull "$pull"
  --cap-add NET_ADMIN --cap-add NET_RAW --cap-add SYSLOG --cap-add SYS_NICE
  -e FIREWALL="${FIREWALL:-true}"
  -e FIREWALL_VERBOSE="${FIREWALL_VERBOSE:-false}"
  -e CLAUDE_CODE_PLUGIN_SEED_DIR=/opt/claude-seed
  -e CLAUDE_CODE_PLUGIN_CACHE_DIR=/home/node/.claude-plugins
  -v ~/.claude:/home/node/.claude
  -v ~/.claude/plugins:/opt/claude-seed:ro
  -v ~/.claude.json:/home/node/.claude.json
  -v "$PWD":/workspace
)

[[ -f ~/.ssh/id_rsa ]] && args+=(-v ~/.ssh/id_rsa:/home/node/.ssh/id_rsa:ro)
[[ -f ~/.kube/config ]] && args+=(-v ~/.kube/config:/home/node/.kube/config:ro)

[[ -n "${GH_TOKEN:-}" ]] && args+=(-e GH_TOKEN="$GH_TOKEN")

while [[ "${1:-}" == "-v" ]]; do
  dir="$2"
  shift 2
  [[ -d "$dir" ]] || { echo "not a directory: $dir" >&2; exit 1; }
  fullpath="$(cd "$dir" && pwd)"
  name="$(basename "$dir")"
  args+=(-v "$fullpath:/mnt/$name")
done

docker run "${args[@]}" kyxap/claude-sandbox "$@"
