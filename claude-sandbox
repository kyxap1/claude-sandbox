#!/usr/bin/env bash
set -euo pipefail

args=(
  --rm -it --pull always
  --cap-add NET_ADMIN --cap-add NET_RAW
  -v ~/.claude:/home/node/.claude
  -v "$PWD":/workspace
)

while [[ "${1:-}" == "-v" ]]; do
  dir="$2"
  shift 2
  [[ -d "$dir" ]] || { echo "not a directory: $dir" >&2; exit 1; }
  fullpath="$(cd "$dir" && pwd)"
  name="$(basename "$dir")"
  args+=(-v "$fullpath:/mnt/$name")
done

docker run "${args[@]}" kyxap/claude-sandbox "$@"
